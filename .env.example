# BTT Genius AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Supabase (get from: https://app.supabase.com -> Project -> Settings -> API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# OpenAI (get from: https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- How to use ---
# When running Flutter, pass these as dart-defines:
#
#   flutter run \
#     --dart-define=SUPABASE_URL=$SUPABASE_URL \
#     --dart-define=SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY \
#     --dart-define=OPENAI_API_KEY=$OPENAI_API_KEY
#
# Or use a run configuration in your IDE (VS Code launch.json / Android Studio):
#
#   "args": [
#     "--dart-define=SUPABASE_URL=https://xxx.supabase.co",
#     "--dart-define=SUPABASE_ANON_KEY=eyJ...",
#     "--dart-define=OPENAI_API_KEY=sk-..."
#   ]
